{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".tsbuildinfo"]
    },
    "build:types": {
      "outputs": ["dist/**/*.d.ts"]
    },
    "build:node": {
      "outputs": ["dist/**/*.node.*"]
    },
    "build:browser": {
      "outputs": ["dist/**/*.browser.*"]
    },
    "build:chains": {
      "outputs": ["dist/chains.*"]
    },
    "build:platform": {
      "outputs": ["dist/platform.*"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint:fix": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": [".tsbuildinfo"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "fetch-abis": {
      "outputs": ["src/abi/**"]
    },
    "clean": {
      "cache": false
    },
    "docs": {
      "dependsOn": ["^build"],
      "outputs": ["docs/**"]
    }
  }
}
